{
  "name": "@stacklych/dredd",
  "version": "0.3.0",
  "description": "HTTP API Testing Framework",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "dredd": "bin/dredd"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "npm run build -- --watch",
    "build": "tsc --build tsconfig.json",
    "lint": "eslint . bin/dredd",
    "prettify": "prettier --write lib/**/*.ts test/**/*.js",
    "prettify:check": "prettier --check lib/**/*.ts test/**/*.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "mocha \"./test/unit/**/*-test.js\"",
    "test:integration": "mocha \"./test/integration/**/*-test.js\"",
    "test:coverage": "c8 npm test",
    "test:smoke": "bash ./scripts/smoke.sh",
    "e2e": "cucumber-js --world-parameters=\"{\\\"apiDescriptionFormat\\\": \\\"application/vnd.oai.openapi\\\"}\"",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacklych/dredd.git"
  },
  "bugs": {
    "url": "https://github.com/stacklych/dredd/issues"
  },
  "files": [
    "bin",
    "build",
    "options.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "async": "3.2.6",
    "caseless": "0.12.0",
    "clone": "2.1.2",
    "cross-spawn": "7.0.6",
    "@stacklych/dredd-transactions": "^0.3.0",
    "glob": "13.0.6",
    "html": "1.0.0",
    "http-proxy-agent": "9.1.0",
    "https-proxy-agent": "9.1.0",
    "inquirer": "14.0.2",
    "js-yaml": "4.2.0",
    "markdown-it": "14.2.0",
    "minimist": "1.2.8",
    "ramda": "0.32.0",
    "spawn-args": "0.2.0",
    "which": "6.0.1",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@types/async": "3.2.25",
    "@types/clone": "2.1.4",
    "@types/js-yaml": "4.0.9",
    "@types/minimist": "1.2.5",
    "@types/mocha": "10.0.10",
    "@types/node": "24.13.2",
    "@types/ramda": "0.31.1",
    "@types/which": "3.0.4",
    "body-parser": "^2",
    "chai": "6.2.2",
    "coffeescript": "2.7.0",
    "@cucumber/cucumber": "13.0.0",
    "eslint": "^10",
    "eslint-config-prettier": "10.1.8",
    "esmock": "2.7.6",
    "express": "^5",
    "globals": "17.6.0",
    "mocha": "11.7.6",
    "nock": "14.0.15",
    "prettier": "3.8.4",
    "ps-node": "0.1.6",
    "sinon": "22.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  },
  "keywords": [
    "api",
    "test",
    "testing",
    "documenation",
    "integration",
    "acceptance"
  ],
  "author": "Apiary Czech Republic, s.r.o. <support@apiary.io>",
  "contributors": [
    {
      "name": "stacklych",
      "url": "https://github.com/stacklych"
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/stacklych/dredd/tree/master/packages/dredd"
}
