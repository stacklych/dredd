{
  "name": "@stacklych/dredd-transactions",
  "version": "0.4.0",
  "description": "Compiles HTTP Transactions (Request-Response pairs) from an API description document",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./parse": "./parse/index.js",
    "./compile": "./compile/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "exit 0",
    "clean": "rimraf ./coverage",
    "lint": "eslint .",
    "pretest": "node ./scripts/pretest.js",
    "test": "npm run clean && mocha",
    "test:coverage": "npm run pretest && c8 mocha",
    "test:smoke": "bash ./scripts/smoke.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacklych/dredd.git"
  },
  "bugs": {
    "url": "https://github.com/stacklych/dredd/issues"
  },
  "files": [
    "index.js",
    "parse",
    "compile",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@apielements/core": "^0.2.1",
    "@apielements/openapi3-parser": "0.16.1",
    "uri-template": "2.0.0",
    "yaml-js": "0.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "ajv": "8.20.0",
    "chai": "6.2.2",
    "eslint": "^10",
    "esmock": "2.7.6",
    "globals": "17.7.0",
    "mocha": "11.7.6",
    "mocha-lcov-reporter": "1.3.0",
    "rimraf": "6.1.3"
  },
  "keywords": [
    "api",
    "test",
    "testing",
    "documenation",
    "integration",
    "acceptance"
  ],
  "author": "Stackly (https://github.com/stacklych)",
  "contributors": [
    {
      "name": "stacklych",
      "url": "https://github.com/stacklych"
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/stacklych/dredd/tree/master/packages/dredd-transactions"
}
